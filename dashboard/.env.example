# Dashboard-only settings. These ADD to the bot's existing .env (BOT_TOKEN,
# DATABASE_URL, OWNER_ID, STAFF_IDS, ...) — the dashboard reuses those. Put these
# keys in the same .env at the repo root, or export them in the dashboard's env.

# ── Discord OAuth2 application ───────────────────────────────────────────────
# Discord Developer Portal → your app → OAuth2.
#   - DISCORD_CLIENT_ID is your application id (same as the bot's).
#   - DISCORD_CLIENT_SECRET is the OAuth2 client secret (NOT the bot token).
# Add the redirect below to the portal's OAuth2 → Redirects list.
DISCORD_CLIENT_ID=your_application_id
DISCORD_CLIENT_SECRET=your_oauth2_client_secret

# Where Discord returns the user after they authorize.
#   dev  : http://localhost:5173/api/auth/callback   (Vite proxies /api to the backend)
#   prod : https://dashboard.yourdomain.com/api/auth/callback
OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/callback

# Where to send the browser after a successful login (the frontend origin).
DASHBOARD_FRONTEND_URL=http://localhost:5173

# Cookie signing secret. Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
DASHBOARD_SESSION_SECRET=change_me_to_a_long_random_string

# Set to 1 in production (HTTPS) so the session cookie is Secure-only.
DASHBOARD_COOKIE_SECURE=0

# Session lifetime in seconds (default 28800 = 8h). Also bounds how long a revoked
# Manage Server permission can still reach the dashboard (access is snapshotted at
# login), so shorten to tighten revocation — e.g. 7200 (2h).
DASHBOARD_SESSION_MAX_AGE=28800
